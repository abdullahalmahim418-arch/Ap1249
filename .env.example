# Local dev only — Vercel injects PORT automatically
PORT=3000
NODE_ENV=development

# FlareSolverr proxy (must be publicly accessible from Vercel's servers)
FLARESOLVERR_URL=http://flaresolverr-anivault.up.railway.app

# Discord relay
BOT_SECRET=your_shared_secret_here
VERCEL_BOT_URL=https://anivault-bot.vercel.app

# Cache TTL in seconds
# NOTE: node-cache is in-memory — these TTLs reset on every Vercel cold start.
# For persistent caching across requests, consider Upstash Redis (free tier).
CACHE_TTL_MAPPING=86400
CACHE_TTL_EPISODES=3600
CACHE_TTL_STREAM=300

# Rate limiting (also in-memory — won't persist across Vercel function instances)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
