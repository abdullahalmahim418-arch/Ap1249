PORT=3000
NODE_ENV=development

# Optional: Upstash Redis for persistent caching (recommended for production)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# Cache TTL in seconds
CACHE_TTL_MAPPING=86400
CACHE_TTL_EPISODES=3600
CACHE_TTL_STREAM=300

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# One-off InfinityFree -> R2 image migration tool (src/image-migrator.ts)
# Delete these + the route once the migration is done.
FTP_HOST=ftpupload.net
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=/htdocs/assets/img/anime-library
MIGRATE_ACCESS_KEY=
